{
  "appId": "com.monacout",
  "appName": "Monac'Out",
  "webDir": "dist",
  "ios": {
    "contentInset": "never",
    "allowsLinkPreview": false,
    "scrollEnabled": false
  },
  "plugins": {
    "Keyboard": {
      "resize": "none"
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#C4A241"
    },
    "SplashScreen": {
      "launchShowDuration": 0,
      "launchAutoHide": false,
      "backgroundColor": "#FFFDF7",
      "showSpinner": false
    },
    "CapacitorUpdater": {
      "autoUpdate": false,
      "resetWhenUpdate": true
    }
  }
}
